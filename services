<style>
  /* --- 1. CSS SE TEXT SELECTION AUR TOUCH GESTURES BLOCK --- */
  html, body {
    /* Mobile me pinch-to-zoom aur double-tap-zoom ko completely disable karne ke liye CSS property */
    touch-action: none !important; 
    touch-action: pan-x pan-y !important; /* Sirf scroll karne dega, zoom nahi */
    
    -webkit-user-select: none !important;  
    -moz-user-select: none !important;     
    -ms-user-select: none !important;      
    user-select: none !important;          
    -webkit-touch-callout: none !important; 
    -webkit-tap-highlight-color: rgba(0,0,0,0) !important;
  }

  /* --- 2. IMAGES PROTECTION --- */
  img {
    -webkit-user-drag: none !important;    
    user-drag: none !important;
    pointer-events: none !important;       
  }

  /* Forms ke andar typing me koi problem na ho, isliye exemption */
  input, textarea, select {
    -webkit-user-select: text !important;
    -moz-user-select: text !important;
    -ms-user-select: text !important;
    user-select: text !important;
    touch-action: auto !important; /* Form fields par default touch action allowed rahega */
  }
</style>

<script>
  (function() {
    // 1. HIGH-PRIORITY VIEWPORT FORCING
    // Yeh meta tag browser ko batata hai ki screen ka zoom level 1.0 par lock rahe
    let viewportMeta = document.querySelector('meta[name="viewport"]');
    if (!viewportMeta) {
      viewportMeta = document.createElement('meta');
      viewportMeta.name = "viewport";
      document.getElementsByTagName('head')[0].appendChild(viewportMeta);
    }
    viewportMeta.content = "width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no, shrink-to-fit=no";

    // 2. JAVASCRIPT TOUCH-GESTURE CORES (CRITICAL FOR MOBILE ZOOM LOCK)
    // Jab koi do ungliyon (2 fingers) se pinch karne ki koshish karega, ye use block karega
    document.addEventListener('touchstart', function(event) {
      if (event.touches.length > 1) {
        event.preventDefault(); // Multi-touch zoom block
      }
    }, { passive: false });

    // Double tap karke zoom karne ki koshish ko block karne ke liye
    let lastTouchEnd = 0;
    document.addEventListener('touchend', function(event) {
      const now = (new Date()).getTime();
      if (now - lastTouchEnd <= 300) {
        event.preventDefault(); // 300ms ke andar double tap block
      }
      lastTouchEnd = now;
    }, { passive: false });

    // 3. DESKTOP VIEW ZOOM DISABLE (Ctrl + Wheel & Keys)
    window.addEventListener('wheel', function(e) {
      if (e.ctrlKey) {
        e.preventDefault();
      }
    }, { passive: false });

    window.addEventListener('keydown', function(e) {
      if (e.ctrlKey && (e.key === '=' || e.key === '-' || e.key === '+' || e.key === '0')) {
        e.preventDefault();
      }
      if (e.ctrlKey && (e.key === 's' || e.key === 'S' || e.key === 'c' || e.key === 'C' || e.key === 'u' || e.key === 'U')) {
        e.preventDefault();
      }
    });

    // 4. SILENT RIGHT-CLICK & COPY DISABLE
    document.addEventListener('contextmenu', function(e) {
      e.preventDefault();
    });

    document.addEventListener('copy', function(e) {
      e.preventDefault();
    });
    
    document.addEventListener('cut', function(e) {
      e.preventDefault();
    });
  })();
</script>
<!-- SIDS Strict Mobile Anti-Zoom & Protection Section End -->



